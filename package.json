{
  "name": "uibit",
  "version": "0.1.0",
  "description": "A collection of accessible, production-ready UI web components",
  "private": true,
  "type": "module",
  "engines": {
    "pnpm": ">=8.0.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "pnpm -r run dev",
    "build": "pnpm -r --filter '!@uibit/docs' run build && pnpm -F docs run build",
    "build:carousel": "pnpm -F carousel run build",
    "build:360-viewer": "pnpm -F 360-viewer run build",
    "build:scroll-progress": "pnpm -F scroll-progress run build",
    "build:hotspot": "pnpm -F hotspot run build",
    "build:consent-guard": "pnpm -F consent-guard run build",
    "build:ab-test": "pnpm -F ab-test run build",
    "build:countdown": "pnpm -F countdown run build",
    "build:scratch-reveal": "pnpm -F scratch-reveal run build",
    "build:signature-pad": "pnpm -F signature-pad run build",
    "build:docs": "pnpm -F docs run build",
    "preview": "pnpm -F docs run preview",
    "analyze": "pnpm -r --filter '!@uibit/docs' --filter '!@uibit/core' run analyze"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "typescript": "7.0.2",
    "vite": "^5.4.21"
  },
  "keywords": [
    "ui",
    "components",
    "web-components",
    "lit",
    "accessible"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/uibit.git"
  }
}
