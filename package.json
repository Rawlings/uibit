{
  "name": "uibit",
  "version": "0.1.0",
  "description": "A collection of accessible, production-ready UI web components",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "pnpm": ">=11.0.0",
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm -F docs run dev",
    "build": "turbo build",
    "build:docs": "pnpm -F docs run build",
    "preview": "pnpm -F docs run preview",
    "analyze": "turbo analyze",
    "lint": "oxlint && turbo typecheck",
    "test": "turbo test"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.3",
    "eslint-plugin-lit": "^1.15.0",
    "eslint-plugin-lit-a11y": "^2.2.0",
    "happy-dom": "^14.12.3",
    "oxlint": "^0.15.0",
    "turbo": "^2.10.4",
    "typescript": "7.0.2",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "ui",
    "components",
    "web-components",
    "lit",
    "accessible"
  ],
  "author": "Jonathan Rawlings",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rawlings/uibit.git"
  },
  "bugs": {
    "url": "https://github.com/rawlings/uibit/issues"
  },
  "homepage": "https://github.com/rawlings/uibit#readme"
}
