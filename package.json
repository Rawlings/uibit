{
  "name": "uibit",
  "version": "0.1.0",
  "description": "A collection of accessible, production-ready UI web components",
  "private": true,
  "type": "module",
  "engines": {
    "pnpm": ">=8.0.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "pnpm -F docs run dev",
    "build": "pnpm -r --filter '!@uibit/docs' run build && pnpm -F docs run build",
    "build:docs": "pnpm -F docs run build",
    "preview": "pnpm -F docs run preview",
    "analyze": "pnpm -r --filter '!@uibit/docs' --filter '!@uibit/core' run analyze",
    "test": "vitest run"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "concurrently": "^9.0.0",
    "happy-dom": "^14.12.3",
    "typescript": "7.0.2",
    "vite": "^5.4.21",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "ui",
    "components",
    "web-components",
    "lit",
    "accessible"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/uibit.git"
  }
}
