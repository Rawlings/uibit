{
  "name": "uibit",
  "version": "0.1.0",
  "description": "A collection of accessible, production-ready UI web components",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "pnpm": ">=11.0.0",
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "pnpm -F docs run dev",
    "build": "turbo build",
    "build:docs": "turbo run build --filter=@uibit/docs",
    "preview": "pnpm -F docs run preview",
    "analyze": "turbo analyze",
    "lint": "turbo run lint:biome typecheck",
    "lint:biome": "biome check",
    "format": "biome format --write",
    "format:check": "biome format",
    "test": "vitest run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@uibit/cem-oxc": "workspace:*",
    "@uibit/hoistlock": "workspace:*",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^1.6.1",
    "concurrently": "^9.2.4",
    "playwright": "^1.61.1",
    "turbo": "^2.10.5",
    "typescript": "7.0.2",
    "vite": "^5.4.21",
    "vitest": "1.6.1"
  },
  "keywords": [
    "ui",
    "components",
    "web-components",
    "lit",
    "accessible"
  ],
  "author": "Jonathan Rawlings",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rawlings/uibit"
  },
  "bugs": {
    "url": "https://github.com/Rawlings/uibit/issues"
  },
  "homepage": "https://github.com/rawlings/uibit#readme",
  "customElements": "dist/custom-elements.json"
}
