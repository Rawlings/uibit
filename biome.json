{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!packages/apps/docs/src/styles/globals.css",
      "!packages/platform/hoistlock/index.js",
      "!packages/platform/hoistlock/index.d.ts",
      "!packages/platform/cem-oxc/index.js",
      "!packages/platform/cem-oxc/index.d.ts",
      "!packages/platform/core/src/locales/en-US.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "useEditorconfig": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": {
        "preset": "recommended"
      },
      "complexity": {
        "preset": "recommended",
        "noThisInStatic": "off"
      },
      "correctness": {
        "preset": "recommended"
      },
      "performance": {
        "preset": "recommended"
      },
      "style": {
        "preset": "recommended"
      },
      "suspicious": {
        "preset": "recommended"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["packages/apps/docs/**/*"],
      "linter": {
        "rules": {
          "suspicious": {
            "noArrayIndexKey": "off"
          }
        }
      }
    }
  ]
}
