{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "tsconfig.*.json", "package.json"],
      "outputs": ["dist/**", "custom-elements.json"]
    },
    "analyze": {
      "inputs": ["src/**", "package.json"],
      "outputs": ["custom-elements.json"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**", "tsconfig.json", "package.json", "vitest.config.*", "vitest.workspace.*"],
      "outputs": []
    }
  }
}
