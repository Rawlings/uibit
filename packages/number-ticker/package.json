{
  "name": "@uibit/number-ticker",
  "version": "0.1.0",
  "description": "Intersection-aware numeric counter that animates to a target value with easing, formatting, and currency support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./custom-elements.json": "./custom-elements.json"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE",
    "custom-elements.json"
  ],
  "scripts": {
    "build": "npm run analyze && tsc",
    "dev": "concurrently \"cem analyze --globs 'src/**/*.ts' --litelement --watch\" \"tsc --watch\"",
    "analyze": "cem analyze --globs 'src/**/*.ts' --litelement"
  },
  "keywords": ["counter", "ticker", "number", "animation", "intersection", "web-component", "lit"],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/uibit.git",
    "directory": "packages/number-ticker"
  },
  "dependencies": {
    "@uibit/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "lit": "^3.3.3",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "customElements": "custom-elements.json"
}
