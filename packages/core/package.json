{
  "name": "@uibit/core",
  "version": "0.1.0",
  "description": "Core utilities and decorators for UIBit web components",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./theme.css"
  },
  "files": [
    "dist",
    "theme.css",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc"
  },
  "keywords": [
    "uibit",
    "core",
    "decorators",
    "web-components",
    "lit"
  ],
  "author": "Jonathan Rawlings",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.43",
    "lit": "^3.3.3",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "dependencies": {
    "@lit/localize": "^0.12.2",
    "lucide": "^1.24.0"
  }
