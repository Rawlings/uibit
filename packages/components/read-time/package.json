{
  "name": "@uibit/read-time",
  "version": "0.2.1",
  "description": "Text-analyzer badge that scans the word count of its slotted content and outputs an estimated reading time string. No backend metadata required — works directly in any CMS template.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./custom-elements.json": "./custom-elements.json",
    "./react": "./dist/frameworks/react/index.ts",
    "./vue": "./dist/frameworks/vue/index.ts",
    "./svelte": "./dist/frameworks/svelte/index.svelte",
    "./angular": "./dist/frameworks/angular/index.ts",
    "./solid": "./dist/frameworks/solid/index.d.ts",
    "./astro": "./dist/frameworks/astro/index.astro",
    "./qwik": "./dist/frameworks/qwik/index.tsx",
    "./nuxt": "./dist/frameworks/nuxt/index.ts",
    "./preact": "./dist/frameworks/preact/index.d.ts",
    "./stencil": "./dist/frameworks/stencil/index.d.ts"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE",
    "custom-elements.json"
  ],
  "scripts": {
    "build": "concurrently \"cem analyze --config ../custom-elements-manifest.config.js && uibit-codegen --package .\" \"tsc\"",
    "dev": "concurrently \"cem analyze --config ../custom-elements-manifest.config.js --watch\" \"tsc --watch\"",
    "analyze": "cem analyze --config ../custom-elements-manifest.config.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "reading-time",
    "text-analysis",
    "badge",
    "cms",
    "web-component",
    "lit"
  ],
  "author": "Jonathan Rawlings",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rawlings/uibit",
    "directory": "packages/components/read-time"
  },
  "dependencies": {
    "@uibit/core": "workspace:*",
    "lucide": "^1.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@uibit/codegen": "workspace:*",
    "lit": "^3.3.3",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "@angular/core": ">=14",
    "lit": "^3.0.0",
    "react": ">=18",
    "svelte": ">=4 || ^5",
    "vue": ">=3"
  },
  "customElements": "custom-elements.json",
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    }
  },
  "uibit": {
    "id": "read-time",
    "title": "Read Time",
    "category": "Text",
    "tagName": "uibit-read-time"
  }
}
