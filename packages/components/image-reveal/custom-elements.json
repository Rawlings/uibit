              "default": "12rem"
            },
            {
              "name": "[--uibit-image-reveal-lens-shadow=0",
              "description": "0 0 0.1875rem #ffffff, 0 0.5rem 2rem rgba(0,0,0,0.35)] - Box shadow of the lens ring"
            }
          ],
          "cssStates": [
            {
              "name": "revealed",
              "description": "Active when the image has completed its reveal transition."
            }
          ],
