              "name": "_lensSize",
              "kind": "method",
              "static": false,
              "privacy": "private",
              "return": {
                "type": {
                  "text": "number"
                }
              }
            },
            {
              "name": "_updateLens",
              "kind": "method",
              "static": false,
              "privacy": "private",
              "parameters": [
                {
                  "name": "clientX",
                  "type": {
                    "text": "number"
                  }
                },
                {
                  "name": "clientY",
                  "type": {
                    "text": "number"
                  }
                }
              ]
            },
            {
              "name": "_onMouseEnter",
              "kind": "field",
              "default": "(e: MouseEvent) => {\n    this.setAttribute('active', '');\n    this._updateLens(e.clientX, e.clientY);\n  }",
              "static": false,
              "privacy": "private"
            },
            {
              "name": "_onMouseMove",
              "kind": "field",
              "default": "(e: MouseEvent) => {\n    this._updateLens(e.clientX, e.clientY);\n  }",
              "static": false,
              "privacy": "private"
            },
            {
              "name": "_onMouseLeave",
              "kind": "field",
              "default": "() => {\n    this.removeAttribute('active');\n  }",
              "static": false,
              "privacy": "private"
            },
            {
              "name": "_onTouchStart",
              "kind": "field",
              "default": "(e: TouchEvent) => {\n    this.setAttribute('touch', '');\n    this.setAttribute('active', '');\n    const t = e.touches[0];\n    if (t) this._updateLens(t.clientX, t.clientY);\n  }",
              "static": false,
              "privacy": "private"
            },
            {
              "name": "_onTouchMove",
              "kind": "field",
              "default": "(e: TouchEvent) => {\n    if (e.cancelable) e.preventDefault();\n    const t = e.touches[0];\n    if (t) this._updateLens(t.clientX, t.clientY);\n  }",
              "static": false,
              "privacy": "private"
            },
            {
              "name": "_onTouchEnd",
              "kind": "field",
              "default": "() => {\n    this.removeAttribute('active');\n  }",
              "static": false,
              "privacy": "private"
            },
            {
              "name": "firstUpdated",
              "kind": "method",
              "static": false,
              "privacy": "public"
            },
