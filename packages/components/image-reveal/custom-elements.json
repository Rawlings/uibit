              "name": "size",
              "description": "Diameter of the lens in any CSS unit. Overrides the CSS custom property.",
              "type": {
                "text": "string"
              },
              "fieldName": "size",
              "default": "''"
            }
          ],
          "events": [
            {
              "name": "reveal-move",
              "description": "Fired as the lens moves; `detail.x` and `detail.y` are percentages",
