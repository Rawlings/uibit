                "text": "string"
              },
              "default": "''",
              "static": false,
              "privacy": "public",
              "attribute": "size"
            },
            {
              "name": "_x",
              "kind": "field",
              "default": "0",
              "static": false,
              "privacy": "private"
            },
            {
              "name": "_y",
              "kind": "field",
              "default": "0",
              "static": false,
              "privacy": "private"
            },
            {
