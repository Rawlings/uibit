{
  "name": "@uibit/table",
  "version": "0.2.0",
  "description": "Wraps any standard HTML <table> in the default slot and adds a full datagrid feature set — without touching the source markup. All features are individually opt-in via boolean attributes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./custom-elements.json": "./custom-elements.json",
    "./react": "./dist/frameworks/react/index.ts",
    "./vue": "./dist/frameworks/vue/index.ts",
    "./svelte": "./dist/frameworks/svelte/index.svelte",
    "./angular": "./dist/frameworks/angular/index.ts",
    "./solid": "./dist/frameworks/solid/index.d.ts",
    "./astro": "./dist/frameworks/astro/index.astro",
    "./qwik": "./dist/frameworks/qwik/index.tsx",
    "./nuxt": "./dist/frameworks/nuxt/index.ts",
    "./preact": "./dist/frameworks/preact/index.d.ts",
    "./stencil": "./dist/frameworks/stencil/index.d.ts"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE",
    "custom-elements.json"
  ],
  "scripts": {
    "build": "concurrently \"cem analyze --config ../custom-elements-manifest.config.js && uibit-codegen --package .\" \"tsc\"",
    "dev": "concurrently \"cem analyze --config ../custom-elements-manifest.config.js --watch\" \"tsc --watch\"",
    "analyze": "cem analyze --config ../custom-elements-manifest.config.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run -c ../../../vitest.config.ts src/ --passWithNoTests"
  },
  "keywords": [
    "table",
    "datatable",
    "filter",
    "sort",
    "pagination",
    "web-component",
    "lit"
  ],
  "author": "Jonathan Rawlings",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rawlings/uibit",
    "directory": "packages/components/table"
  },
  "dependencies": {
    "@uibit/core": "workspace:*",
    "lucide": "^1.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@uibit/codegen": "workspace:*",
    "lit": "^3.3.3",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "lit": "^3.0.0",
    "react": ">=18",
    "vue": ">=3",
    "svelte": ">=4 || ^5",
    "@angular/core": ">=14"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    }
  },
  "customElements": "custom-elements.json",
  "uibit": {
    "id": "table",
    "title": "Table",
    "category": "Data",
    "tagName": "uibit-table"
  }
}
