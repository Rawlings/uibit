        {
          "kind": "class",
          "name": "ConsentGuard",
          "tagName": "uibit-consent-guard",
          "customElement": true,
          "description": "Gate any content behind a consent prompt. Shows the `placeholder` slot until",
          "summary": "A cookie and privacy consent guard wrapping third-party embedded resources.\nthe user grants consent, then reveals the default slot.\nConsent is triggered by clicking any element with `[data-consent-accept]`\ninside the placeholder slot, or by calling the `accept()` method programmatically.\nContent in the default slot is kept `display:none` until consent is granted,\nso iframes with `loading=\"lazy\"` will not make network requests beforehand.",
          "members": [
            {
              "name": "styles",
              "kind": "field",
              "default": "css`\n    :host {\n      display: block;\n      width: 100%;\n    }\n\n    .placeholder {\n      width: 100%;\n    }\n\n    .content {\n      display: none;\n      width: 100%;\n    }\n\n    :host([consented]) .placeholder {\n      display: none;\n    }\n\n    :host([consented]) .content {\n      display: block;\n    }\n  `",
              "static": true,
              "privacy": "public"
            },
            {
              "name": "_consented",
              "kind": "field",
              "default": "false",
              "static": false,
              "privacy": "private"
            },
            {
              "name": "accept",
              "kind": "method",
              "description": "Programmatically grant consent.",
              "static": false,
              "privacy": "public"
            },
            {
              "name": "_onPlaceholderClick",
              "kind": "method",
              "static": false,
              "privacy": "private",
              "parameters": [
                {
                  "name": "e",
                  "type": {
                    "text": "Event"
                  }
                }
              ]
            },
            {
              "name": "render",
              "kind": "method",
              "static": false,
              "privacy": "public"
            }
          ],
          "attributes": [],
          "events": [
            {
              "name": "consent-accepted",
              "description": "Fired when consent is granted"
            }
          ],
          "slots": [
            {
              "name": "placeholder",
              "description": "Shown before consent. Put your prompt UI here. Mark your\naccept button with `data-consent-accept`."
            },
            {
              "name": "(default)",
              "description": "The content to reveal after consent (e.g. an iframe)."
            }
          ],
          "cssParts": [
            {
              "name": "placeholder",
              "description": "Wrapper around the placeholder slot"
            },
            {
              "name": "content",
              "description": "Wrapper around the default slot"
            }
          ],
