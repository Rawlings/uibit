{
  "name": "@uibit/scroll-progress",
  "version": "0.1.0",
  "description": "A web component that visualizes scroll progress on the page",
  "type": "module",
  "main": "./dist/scroll-progress.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/scroll-progress.js"
    },
    "./scroll-progress.css": "./dist/scroll-progress.css",
    "./custom-elements.json": "./custom-elements.json"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE",
    "custom-elements.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run analyze && vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "analyze": "cem analyze --globs 'src/**/*.ts' --litelement"
  },
  "keywords": [
    "scroll-progress",
    "progress-bar",
    "web-component",
    "lit",
    "scroll"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/uibit.git",
    "directory": "packages/scroll-progress"
  },
  "dependencies": {
    "@uibit/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "lit": "^3.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.7"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "customElements": "custom-elements.json"
}
