{
  "name": "@uibit/sentiment-bar",
  "version": "0.1.0",
  "description": "Micro-feedback widget with expressive sliding icons that blend between states and fire scored events on release",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./custom-elements.json": "./custom-elements.json",
    "./react": {
      "types": "./dist/frameworks/react/index.d.ts",
      "import": "./dist/frameworks/react/index.js"
    },
    "./vue": "./dist/frameworks/vue/index.ts",
    "./svelte": "./dist/frameworks/svelte/index.svelte",
    "./angular": "./dist/frameworks/angular/index.ts",
    "./solid": "./dist/frameworks/solid/index.d.ts",
    "./astro": "./dist/frameworks/astro/index.astro",
    "./qwik": "./dist/frameworks/qwik/index.tsx",
    "./nuxt": "./dist/frameworks/nuxt/index.ts"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE",
    "custom-elements.json"
  ],
  "scripts": {
    "build": "npm run analyze && uibit-codegen --package . && tsc",
    "dev": "concurrently \"cem analyze --globs 'src/**/*.ts' --litelement --watch\" \"tsc --watch\"",
    "analyze": "cem analyze --globs 'src/**/*.ts' --litelement"
  },
  "keywords": [
    "sentiment",
    "feedback",
    "rating",
    "emoji",
    "micro-interaction",
    "web-component",
    "lit"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/uibit.git",
    "directory": "packages/sentiment-bar"
  },
  "dependencies": {
    "@uibit/core": "workspace:*",
    "lucide": "^1.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "lit": "^3.3.3",
    "typescript": "7.0.2",
    "@uibit/codegen": "workspace:*"
  },
  "peerDependencies": {
    "lit": "^3.0.0",
    "react": ">=18",
    "vue": ">=3",
    "svelte": ">=4 || ^5",
    "@angular/core": ">=14"
  },
  "customElements": "custom-elements.json",
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    }
  }
}
