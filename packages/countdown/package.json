{
  "name": "@uibit/countdown",
  "version": "0.1.0",
  "description": "A web component for displaying countdown timers with customizable formatting",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./countdown.css": "./dist/countdown.css",
    "./custom-elements.json": "./custom-elements.json"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE",
    "custom-elements.json"
  ],
  "scripts": {
    "build": "npm run analyze && tsc",
    "analyze": "cem analyze --globs 'src/**/*.ts' --litelement"
  },
  "keywords": [
    "countdown",
    "timer",
    "web-component",
    "lit",
    "event"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/uibit.git",
    "directory": "packages/countdown"
  },
  "dependencies": {
    "@uibit/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "lit": "^3.3.3",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "customElements": "custom-elements.json"
}
