    "typecheck": "tsc --noEmit",
    "test": "vitest run -c ../../../vitest.config.ts --passWithNoTests"
  },
  "keywords": [
    "uibit",
    "form",
    "element-internals",
    "validation",
    "web-components",
    "lit"
  ],
  "author": "Jonathan Rawlings",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.43",
    "lit": "^3.3.3"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Rawlings/uibit",
    "directory": "packages/platform/form-internals"
  }
}
