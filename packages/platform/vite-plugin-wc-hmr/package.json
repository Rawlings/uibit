{
  "name": "@uibit/vite-plugin-wc-hmr",
  "version": "0.1.1",
  "description": "Vite plugin for true Hot Module Replacement of custom elements",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "uibit",
    "hmr",
    "vite",
    "web-components",
    "custom-elements",
    "lit",
    "hot-module-replacement",
    "shadow-dom"
  ],
  "author": "Jonathan Rawlings",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.43",
    "vite": "^6.4.3"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Rawlings/uibit",
    "directory": "packages/platform/vite-plugin-wc-hmr"
  }
}
